<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark variant — used automatically when the OS is in dark mode.
         Color matches the web UI's `--bg` (#0e1015). Light icons on
         status/nav bar so they read against the dark fill. -->
    <style name="Theme.Thescanner" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">#0E1015</item>
        <item name="android:windowBackground">#0E1015</item>
        <item name="android:navigationBarColor">#0E1015</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
